# ============================================
# BookRank - 环境变量配置示例
# 适用于 Render 免费版部署
# ============================================

# ============================================
# 安全配置（必需）
# ============================================

# Flask 安全密钥
# Render 免费版：请使用强随机字符串
# 生成方法：python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-secret-key-here-change-in-production

# Flask 运行环境
# Render 生产环境：production
# 本地开发：development
FLASK_ENV=development

# 网站基础 URL（用于邮件中构建完整图片链接）
# 例如：https://bookrank-ckml.onrender.com
BASE_URL=https://your-app-name.onrender.com

# ============================================
# 数据库配置（Render 免费版自动提供）
# ============================================

# Render PostgreSQL 数据库 URL
# 在 Render 控制面板中添加数据库后会自动提供
# 格式：postgresql://user:password@host:port/dbname
# DATABASE_URL=postgresql://...

# ============================================
# API 密钥配置（必需）
# ============================================

# 纽约时报 Books API 密钥
# 获取地址：https://developer.nytimes.com
NYT_API_KEY=your_nyt_api_key_here

# Google Books API 密钥
# 获取地址：https://console.cloud.google.com
GOOGLE_API_KEY=your_google_api_key_here

# 智谱 AI API 密钥（用于翻译）
# 获取地址：https://open.bigmodel.cn
ZHIPU_API_KEY=your_zhipu_api_key_here

# 百度翻译 API（可选，备选翻译服务）
# 获取地址：https://fanyi-api.baidu.com
# BAIDU_FY_APP_ID=your_baidu_app_id
# BAIDU_FY_APP_KEY=your_baidu_app_key

# 腾讯翻译 API（可选，备选翻译服务）
# 获取地址：https://cloud.tencent.com/product/tmt
# TENCENT_FY_SECRET_ID=your_tencent_secret_id
# TENCENT_FY_SECRET_KEY=your_tencent_secret_key

# XAI API 密钥（可选，用于AI周报生成）
# XAI_API_KEY=your_xai_api_key

# 火山方舟 API 密钥（可选，用于AI周报生成）
# ARK_API_KEY=your_ark_api_key

# Hardcover API Token（可选，用于图书数据补充）
# HARDCOVER_API_TOKEN=your_hardcover_api_token

# ============================================
# 缓存配置（Render 免费版优化）
# ============================================

# 缓存类型（simple/redis）
CACHE_TYPE=simple

# 缓存时间（秒）
# Render 免费版：建议使用更长的时间减少数据库访问
CACHE_TTL=7200

# 内存缓存时间（秒）
MEMORY_CACHE_TTL=600

# ============================================
# API 限流配置
# ============================================

# API 限流（每分钟最大请求数）
API_RATE_LIMIT=100

# 限流窗口（秒）
API_RATE_LIMIT_WINDOW=60

# ============================================
# 并发配置（Render 免费版优化）
# ============================================

# 最大工作线程数
MAX_WORKERS=2

# API 超时时间（秒）
API_TIMEOUT=15

# ============================================
# Gunicorn 配置（Render 免费版）
# ============================================

# Web 并发数（Render 免费版建议 1）
WEB_CONCURRENCY=1

# 每个 Worker 的线程数（Render 免费版建议 2）
GUNICORN_THREADS=2

# ============================================
# 邮件服务配置（可选，用于周报邮件发送）
# ============================================

# SMTP 服务器（如 Gmail: smtp.gmail.com）
# MAIL_SERVER=smtp.gmail.com

# SMTP 端口（TLS: 587, SSL: 465）
# MAIL_PORT=587

# 是否使用 TLS
# MAIL_USE_TLS=true

# SMTP 用户名（邮箱地址）
# MAIL_USERNAME=your-email@gmail.com

# SMTP 密码
# ⚠️ 重要：如果你使用 Gmail，这里不能填你的 Gmail 登录密码！
# 必须生成"应用专用密码"(App Password)：
# 1. 开启 Gmail 两步验证：https://myaccount.google.com/security
# 2. 搜索"应用专用密码"，生成一个 16 位密码
# 3. 将生成的 16 位密码填入此处（不含空格）
# MAIL_PASSWORD=abcd efgh ijkl mnop

# 发件人地址
# MAIL_DEFAULT_SENDER=your-email@gmail.com

# 邮件收件人（逗号分隔多个邮箱）
# MAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# ============================================
# 生产环境安全配置（可选）
# ============================================

# CORS 允许的来源（生产环境）
# 多个来源用逗号分隔，如：https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=
